generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum UserRole {
  admin
  operator
  client
  field_officer
  finance
  analyst      // Laboratorium analis - melakukan analisis sampel
  reporting    // Staff reporting - menerbitkan laporan hasil uji
}

// Notification Types
enum NotificationType {
  sampling_completed
  analysis_ready
  analysis_completed
  reporting_completed
  invoice_generated
  invoice_sent
  payment_received
  job_assigned
  approval_requested
  approval_decided
}

enum JobStatus {
  scheduled
  sampling
  analysis_ready  // Sampling selesai, siap untuk analisis
  analysis        // Sedang dianalisis oleh analis
  analysis_done   // Analisis selesai, menunggu reporting
  reporting       // Sedang dibuat laporan oleh staff reporting
  completed
  pending_payment
  paid
}

enum QuotationStatus {
  draft
  sent
  accepted
  rejected
  paid
}

enum SamplingStatus {
  pending
  in_progress
  completed
  cancelled
}

enum OperationalCategory {
  perdiem
  transport
}

enum ApprovalRequestType {
  edit
  delete
}

enum ApprovalRequestStatus {
  pending
  approved
  rejected
}

model OperationalCatalog {
  id          String              @id @default(uuid())
  category    OperationalCategory
  perdiem_type String?
  location    String?
  distance_category String?
  name        String
  description String?
  price       Decimal             @db.Decimal
  unit        String              @default("unit")
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  history     OperationalHistory[]

  @@map("operational_catalog")
}

model OperationalHistory {
  id          String   @id @default(uuid())
  catalog_id  String
  catalog     OperationalCatalog @relation(fields: [catalog_id], references: [id], onDelete: Cascade)
  action      String   // create, update, delete
  old_price   Decimal? @db.Decimal
  new_price   Decimal? @db.Decimal
  changed_by  String?
  changed_at  DateTime @default(now())

  @@map("operational_history")
}

model Profile {
  id                   String              @id @default(uuid())
  email                String?             @unique
  full_name            String?
  role                 UserRole            @default(client)
  company_name         String?
  address              String?
  phone                String?
  created_at           DateTime            @default(now())
  quotations           Quotation[]
  sampling_assignments SamplingAssignment[]
  approval_requests    ApprovalRequest[]
  notifications        Notification[]

  // Analyst & Reporting Relations
  analyst_jobs         JobOrder[]          @relation("AnalystJobs")
  reporting_jobs       JobOrder[]          @relation("ReportingJobs")
  lab_analyses         LabAnalysis[]

  // Handover Relations
  sent_handovers       SampleHandover[]    @relation("SenderHandover")
  received_handovers   SampleHandover[]    @relation("ReceiverHandover")

  // Finance Relations
  payments_handled     Payment[]           @relation("FinanceHandler")

  @@map("profiles")
  @@index([email])
  @@index([role])
  @@index([created_at])
}

model ServiceCategory {
  id         String    @id @default(uuid())
  name       String    @unique
  created_at DateTime  @default(now())
  services   Service[]

  @@map("service_categories")
}

model Service {
  id           String           @id @default(uuid())
  category_id  String?
  category_ref ServiceCategory? @relation(fields: [category_id], references: [id])
  category     String?          // Made optional for migration
  name         String
  price       Decimal         @db.Decimal
  parameters  Json?
  regulation  String?
  regulation_id String?         // Relasi ke Regulation
  regulation_ref Regulation?    @relation(fields: [regulation_id], references: [id])
  unit        String?
  created_at  DateTime        @default(now())
  items       QuotationItem[]

  @@map("services")
  @@index([category_id])
  @@index([name])
  @@index([created_at])
  @@index([regulation_id])
}

model Quotation {
  id               String          @id @default(uuid())
  quotation_number String          @unique
  user_id          String
  profile          Profile         @relation(fields: [user_id], references: [id])
  date             DateTime        @default(now())
  subtotal         Decimal         @default(0) @db.Decimal
  discount_amount  Decimal         @default(0) @db.Decimal
  use_tax          Boolean         @default(true)
  tax_amount       Decimal         @default(0) @db.Decimal

  // Additional Costs
  perdiem_name     String?
  perdiem_price    Decimal         @default(0) @db.Decimal
  perdiem_qty      Int             @default(0)
  transport_name   String?
  transport_price  Decimal         @default(0) @db.Decimal
  transport_qty    Int             @default(0)

  total_amount     Decimal         @default(0) @db.Decimal
  status           QuotationStatus @default(draft)
  created_at       DateTime        @default(now())
  items            QuotationItem[]
  job_orders       JobOrder[]
  invoices         Invoice[]

  @@map("quotations")
  @@index([user_id])
  @@index([status])
  @@index([created_at])
  @@index([quotation_number])
}

model QuotationItem {
  id                 String    @id @default(uuid())
  quotation_id       String
  quotation          Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  service_id         String?
  service            Service?  @relation(fields: [service_id], references: [id])
  equipment_id       String?
  equipment          Equipment? @relation(fields: [equipment_id], references: [id])
  qty                Int       @default(1)
  price_snapshot     Decimal   @db.Decimal
  parameter_snapshot String?

  @@map("quotation_items")
}

model JobOrder {
  id                  String              @id @default(uuid())
  quotation_id        String
  quotation           Quotation           @relation(fields: [quotation_id], references: [id])
  tracking_code       String              @unique
  status              JobStatus           @default(scheduled)
  notes               String?             // Added for progress remarks
  certificate_url     String?

  // Analyst & Reporting Tracking
  analyst_id          String?             // Analis yang menangani
  analyst             Profile?            @relation("AnalystJobs", fields: [analyst_id], references: [id])
  reporting_id        String?             // Staff reporting yang menangani
  reporting           Profile?            @relation("ReportingJobs", fields: [reporting_id], references: [id])
  analysis_started_at DateTime?           // Waktu analisis dimulai
  analysis_done_at    DateTime?           // Waktu analisis selesai
  reporting_done_at   DateTime?           // Waktu laporan selesai

  created_at          DateTime            @default(now())
  sampling_assignment SamplingAssignment?
  lab_analysis        LabAnalysis?        // Hasil analisis laboratorium
  sample_handover     SampleHandover?     // Berita Acara Serah Terima (BAST)
  payment             Payment?
  invoice             Invoice?

  @@map("job_orders")
  @@index([quotation_id])
  @@index([status])
  @@index([tracking_code])
  @@index([created_at])
  @@index([analyst_id])
  @@index([reporting_id])
}

// Berita Acara Serah Terima (BAST) Sampel
model SampleHandover {
  id                String   @id @default(uuid())
  job_order_id      String   @unique
  job_order         JobOrder @relation(fields: [job_order_id], references: [id], onDelete: Cascade)
  handover_number   String   @unique // BAST-XXXX
  received_at       DateTime @default(now())
  
  sender_id         String   // Biasanya Field Officer
  sender            Profile  @relation("SenderHandover", fields: [sender_id], references: [id])
  receiver_id       String   // Biasanya Analis
  receiver          Profile  @relation("ReceiverHandover", fields: [receiver_id], references: [id])
  
  sample_condition  String   // Misal: Segel Utuh, Dingin, Wadah Pecah, dll
  sample_qty        Int      // Jumlah wadah/botol
  sample_notes      String?  
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("sample_handovers")
  @@index([job_order_id])
  @@index([sender_id])
  @@index([receiver_id])
}

model SamplingAssignment {
  id               String          @id @default(uuid())
  job_order_id     String          @unique
  job_order        JobOrder        @relation(fields: [job_order_id], references: [id], onDelete: Cascade)
  field_officer_id String
  field_officer    Profile         @relation(fields: [field_officer_id], references: [id])
  status           SamplingStatus  @default(pending)
  scheduled_date   DateTime
  actual_date      DateTime?
  location         String
  notes            String?
  photos           Json?           // Array of photo URLs
  created_at       DateTime        @default(now())
  updated_at       DateTime        @default(now())
  travel_order     TravelOrder?

  @@map("sampling_assignments")
  @@index([field_officer_id])
  @@index([status])
  @@index([job_order_id])
  @@index([scheduled_date])
}

model TravelOrder {
  id                  String           @id @default(uuid())
  assignment_id       String           @unique
  assignment          SamplingAssignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  document_number     String           @unique
  departure_date      DateTime
  return_date         DateTime
  destination         String
  purpose             String
  transportation_type String?
  accommodation_type  String?
  daily_allowance     Decimal?         @db.Decimal(10, 2)
  total_budget        Decimal?         @db.Decimal(10, 2)
  notes               String?
  pdf_url             String?
  created_at          DateTime         @default(now())
  updated_at          DateTime         @default(now())

  @@map("travel_orders")
  @@index([assignment_id])
  @@index([document_number])
  @@index([created_at])
}

model CompanyProfile {
  id              String   @id @default(uuid())
  company_name    String   @default("WahfaLab")
  address         String?
  phone           String?
  whatsapp        String?
  email           String?
  website         String?
  logo_url        String?
  tagline         String?
  npwp            String?
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  @@map("company_profiles")
}

// Hasil Analisis Laboratorium
model LabAnalysis {
  id                  String   @id @default(uuid())
  job_order_id        String   @unique
  job_order           JobOrder @relation(fields: [job_order_id], references: [id], onDelete: Cascade)
  analyst_id          String
  analyst             Profile  @relation(fields: [analyst_id], references: [id])
  
  // Hasil Analisis
  test_results        Json?    // Hasil uji per parameter: [{parameter, result, unit, method, limit}]
  analysis_notes      String?  // Catatan analis
  equipment_used      Json?    // Peralatan yang digunakan
  sample_condition    String?  // Kondisi sampel saat diterima
  
  // Dokumen PDF
  result_pdf_url      String?  // URL PDF hasil analisis
  raw_data_url        String?  // URL data mentah (foto, dll)
  
  // Timeline
  analysis_started_at DateTime?
  analysis_completed_at DateTime?
  
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now())

  @@map("lab_analyses")
  @@index([job_order_id])
  @@index([analyst_id])
}

// Regulasi dan Standar Layanan
model Regulation {
  id                  String   @id @default(uuid())
  name                String   @unique  // Nama regulasi (SNI, ISO, dll)
  code                String?  // Kode regulasi
  parameters_list     String[] @default([]) // List parameter utama (tags)
  status              String   @default("active")  // active, inactive, draft
  parameters          RegulationParameter[]
  services            Service[]
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now())

  @@map("regulations")
  @@index([name])
  @@index([status])
}

// Parameter dalam Regulasi
model RegulationParameter {
  id                  String   @id @default(uuid())
  regulation_id       String
  regulation          Regulation @relation(fields: [regulation_id], references: [id], onDelete: Cascade)
  parameter_name      String   // Nama parameter uji
  method              String?  // Metode uji
  unit                String?  // Satuan
  limit_min           String?  // Batas minimum
  limit_max           String?  // Batas maksimum
  limit_value         String?  // Nilai batas (untuk single value)
  requirements        String?  // Persyaratan
  sequence            Int      @default(0)  // Urutan parameter
  is_mandatory        Boolean  @default(true)  // Wajib atau tidak
  notes               String?  // Catatan
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now())

  @@map("regulation_parameters")
  @@index([regulation_id])
  @@index([parameter_name])
}

model Equipment {
  id                String   @id @default(uuid())
  name              String
  category          String?
  specification     String?
  price             Decimal  @db.Decimal
  unit              String   @default("unit")
  availability_status String @default("available")
  quantity          Int      @default(1)
  description       String?
  image_url         String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  quotation_items   QuotationItem[]

  @@map("equipment")
  @@index([name])
  @@index([category])
  @@index([availability_status])
}

model ApprovalRequest {
  id              String                @id @default(uuid())
  request_type    ApprovalRequestType
  status          ApprovalRequestStatus @default(pending)
  entity_type     String                // "quotation", "job_order", etc.
  entity_id       String
  requester_id    String
  requester       Profile               @relation(fields: [requester_id], references: [id])
  reason          String
  old_data        Json?                 // Snapshot data lama untuk edit
  new_data        Json?                 // Snapshot data baru untuk edit
  reviewed_by     String?
  reviewed_at     DateTime?
  rejection_reason String?
  created_at      DateTime              @default(now())
  updated_at      DateTime              @default(now())

  @@map("approval_requests")
  @@index([entity_type, entity_id])
  @@index([requester_id])
  @@index([status])
  @@index([created_at])
}

// Notifications for real-time updates
model Notification {
  id          String            @id @default(uuid())
  user_id     String
  user        Profile           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  message     String
  link        String?           // Optional link to related page
  is_read     Boolean           @default(false)
  metadata    Json?             // Additional data (job_id, invoice_id, etc.)
  created_at  DateTime          @default(now())

  @@map("notifications")
  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
  @@index([type])
}

// Invoices for billing
model Invoice {
  id                String        @id @default(uuid())
  invoice_number    String        @unique
  job_order_id      String        @unique
  job_order         JobOrder      @relation(fields: [job_order_id], references: [id])
  quotation_id      String
  quotation         Quotation     @relation(fields: [quotation_id], references: [id])
  amount            Decimal       @db.Decimal(10, 2)
  status            InvoiceStatus @default(draft)
  due_date          DateTime
  paid_at           DateTime?
  notes             String?
  pdf_url           String?       // Generated PDF invoice
  created_by        String?       // User who created the invoice
  created_at        DateTime      @default(now())
  updated_at        DateTime      @default(now())
  payments          Payment[]

  @@map("invoices")
  @@index([job_order_id])
  @@index([invoice_number])
  @@index([status])
  @@index([due_date])
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // create, update, delete, login, logout, etc.
  entity_type String   // "quotation", "job_order", "user", etc.
  entity_id   String?
  user_id     String?
  user_email  String?
  user_role   String?
  ip_address  String?
  user_agent  String?
  old_data    Json?    // Snapshot sebelum perubahan
  new_data    Json?    // Snapshot setelah perubahan
  metadata    Json?    // Additional context
  created_at  DateTime @default(now())

  @@map("audit_logs")
  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([action])
  @@index([created_at])
}

enum PaymentMethod {
  cash
  transfer
}

enum PaymentStatus {
  pending
  paid
  cancelled
}

model Payment {
  id                String        @id @default(uuid())
  job_order_id      String        @unique
  job_order         JobOrder      @relation(fields: [job_order_id], references: [id])
  invoice_id        String?       @unique
  invoice           Invoice?      @relation(fields: [invoice_id], references: [id])
  invoice_number    String        @unique
  amount            Decimal       @db.Decimal(10, 2)
  payment_method    PaymentMethod?
  payment_status    PaymentStatus @default(pending)
  transfer_reference String?      // Nomor referensi transfer
  paid_at           DateTime?
  handled_by        String?       // Finance user who processed
  handler           Profile?      @relation("FinanceHandler", fields: [handled_by], references: [id])
  created_at        DateTime      @default(now())
  updated_at        DateTime      @default(now())

  @@map("payments")
  @@index([job_order_id])
  @@index([invoice_number])
  @@index([payment_status])
  @@index([handled_by])
}
